# Copy to .env and fill in the values you have. Anything left blank uses
# the defaults baked into docker-compose.yml.

# Logging — info | debug | warn | error
LOG_LEVEL=info

# HTTP listen port (host network mode, so make sure nothing else uses it)
RELAY_PORT=8787

# Persistent data directory inside the container. Stores tokens.json, apns.p8,
# and the Hue Music Ambience config uploaded by the iOS app.
DATA_DIR=/app/data

# Shared secret for /internal/* (Python agent). Generate a long random string.
# If unset, internal routes return 503.
INTERNAL_API_TOKEN=

# Pick any always-on Sonos speaker on your LAN. The relay reads ZoneGroupTopology
# from this seed and discovers the rest of your household automatically.
SONOS_SEED_IP=192.168.50.251

# Hue Music Ambience — iOS uploads Bridge credentials and assignments here.
HUE_AMBIENCE_ENABLED=true
HUE_AMBIENCE_CONFIG_PATH=/app/data/hue-ambience-config.json
# Optional NAS override for Light Motion Speed. Leave blank to use the iOS app
# setting. Lower values move faster; examples: 8, 6, 4.
HUE_FLOW_INTERVAL_SECONDS=

# Hue Entertainment / EDK sidecar. The sidecar listens on NAS loopback by
# default, and the relay talks to it through HUE_EDK_SIDECAR_URL.
HUE_RENDERER=edk-sidecar
HUE_EDK_SIDECAR_HOST=127.0.0.1
HUE_EDK_SIDECAR_PORT=8788
HUE_EDK_SIDECAR_URL=http://127.0.0.1:8788
HUE_EDK_SIDECAR_TOKEN=
HUE_EDK_SIDECAR_TARGET_FPS=60
HUE_EDK_SIDECAR_SESSION_POLICY=reuse

# APNs — leave blank until you have an Apple Developer account + .p8 key.
# When blank the relay runs in dry-run mode and only logs payloads.
APNS_BUNDLE_ID=com.charm.SonosWidget
APNS_KEY_PATH=/app/data/apns.p8
APNS_KEY_ID=
APNS_TEAM_ID=
# Set to "true" once you ship a TestFlight / App Store build (production APNs).
APNS_PRODUCTION=false
